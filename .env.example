# DigitalOcean Inference
DIGITAL_OCEAN_MODEL_ACCESS_KEY=doo_v1_...

# Google AI (get from aistudio.google.com)
GOOGLE_API_KEY=AIza...

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/darwin_sre?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB=darwin_sre

# Models (defaults shown)
SRE_MODEL=claude-sonnet-4-5
MUTATOR_MODEL=claude-haiku-4-5
JUDGE_MODEL=gemini-2.0-flash

# Darwin config
DARWIN_TRIGGER_THRESHOLD=0.60
DARWIN_MAX_GENERATIONS=10
DARWIN_WINDOW_SIZE=5
